          "name": "Get All Users",
          "request": {
            "method": "GET",
            "description": "Returns paginated users with optional filters.",
            "url": {
              "raw": "{{baseUrl}}/users/admin/all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "admin",
                "all"
              ],
              "query": [
                {
                  "key": "role",
                  "value": "student",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "nur",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "20",
                  "disabled": true
                }
              ]
            },
            "auth": {
