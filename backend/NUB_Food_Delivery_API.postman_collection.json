{
  "info": {
    "name": "NUB Food Delivery API - Complete",
    "description": "Complete Postman documentation for the NUB Food Delivery backend.\n\nBase URL:\n- {{baseUrl}} (default: http://localhost:5000/api/v1)\n\nAuth tokens:\n- authToken: for student or normal authenticated calls\n- adminToken: for admin-only endpoints\n\nQuick flow:\n1. Run Health Check\n2. Register or Login\n3. Use Menu endpoints to get categoryId/menuItemId\n4. Use Cart and Orders endpoints\n5. Use Admin folders with adminToken\n\nThe collection auto-saves useful IDs and tokens from several responses into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "menuItemId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Service status endpoint.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "description": "Checks API availability and returns a timestamp.",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "description": "Register, login, password reset, and current user endpoints.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "description": "Creates a student user and returns JWT token.\nRequired fields: name, email, studentId, phone, password",
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nur Mohammad\",\n  \"email\": \"nur@example.com\",\n  \"studentId\": \"42230301051\",\n  \"phone\": \"01712345678\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json?.data?.token) pm.collectionVariables.set('authToken', json.data.token);",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('userId', json.data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "description": "Logs in user and returns JWT token.",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nur@example.com\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json?.data?.token) pm.collectionVariables.set('authToken', json.data.token);",
                  "if (json?.data?.user?.role === 'admin' && json?.data?.token) pm.collectionVariables.set('adminToken', json.data.token);",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('userId', json.data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "description": "Sends password reset email.\nCopy reset token from your email/reset URL and set collection variable resetToken manually.",
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "forgot-password"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nur@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "description": "Resets password with reset token and returns a new JWT token.",
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password/{{resetToken}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "reset-password",
                "{{resetToken}}"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"NewPassword123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json?.data?.token) pm.collectionVariables.set('authToken', json.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "description": "Returns authenticated user profile.",
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
