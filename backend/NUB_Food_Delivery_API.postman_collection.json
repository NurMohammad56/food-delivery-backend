          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json?.data?.length) {",
                  "  const firstNonAdmin = json.data.find(u => u.role !== 'admin') || json.data[0];",
